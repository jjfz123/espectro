{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "convocatoria.schema.json",
  "title": "Convocatoria electoral documentada",
  "type": "object",
  "required": [
    "id",
    "nombre",
    "tipo",
    "fecha",
    "territorio",
    "umbralPorcentaje",
    "denominador",
    "totalCandidaturasOficiales",
    "fuente",
    "candidaturas"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "nombre": { "type": "string", "minLength": 5 },
    "tipo": { "enum": ["generales", "autonomicas", "municipales", "europeas"] },
    "fecha": { "type": "string", "format": "date" },
    "territorio": {
      "type": "string",
      "description": "espana o el id normalizado de una comunidad autónoma"
    },
    "camara": { "type": "string" },
    "umbralPorcentaje": { "type": "number", "minimum": 0, "maximum": 100 },
    "denominador": {
      "type": "object",
      "required": ["tipo", "valor"],
      "properties": {
        "tipo": { "enum": ["votos-a-candidaturas", "votos-validos"] },
        "valor": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "totalCandidaturasOficiales": { "type": "integer", "minimum": 1 },
    "fuente": {
      "type": "object",
      "required": ["titulo", "url", "consultado"],
      "properties": {
        "titulo": { "type": "string", "minLength": 5 },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "fechaDatos": { "type": "string", "format": "date" },
        "consultado": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    },
    "fuentesAdicionales": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["titulo", "url", "consultado"],
        "properties": {
          "titulo": { "type": "string", "minLength": 5 },
          "url": { "type": "string", "format": "uri", "pattern": "^https://" },
          "fechaDatos": { "type": "string", "format": "date" },
          "consultado": { "type": "string", "format": "date" }
        },
        "additionalProperties": false
      }
    },
    "nota": { "type": "string", "minLength": 10 },
    "candidaturas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "nombre",
          "votos",
          "porcentaje",
          "motivoInclusion",
          "perfilRelaciones"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "codigoOficial": { "type": "string" },
          "siglas": { "type": "string" },
          "nombre": { "type": "string", "minLength": 1 },
          "votos": { "type": "integer", "minimum": 0 },
          "porcentaje": { "type": "number", "minimum": 0, "maximum": 100 },
          "escanos": { "type": "integer", "minimum": 0 },
          "territorios": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string" },
            "description": "CCAA donde constan votos; no equivale a municipio ni sección concreta"
          },
          "circunscripciones": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string" }
          },
          "variantesPapeleta": {
            "type": "object",
            "additionalProperties": { "type": "string", "minLength": 1 }
          },
          "motivoInclusion": {
            "enum": ["umbral", "historica-activa", "comunista-activa"]
          },
          "perfilRelaciones": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["perfilId", "relacion"],
              "properties": {
                "perfilId": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                "relacion": {
                  "enum": ["misma-organizacion", "organizacion-territorial", "coalicion", "componente", "sucesora"]
                },
                "nota": { "type": "string", "minLength": 10 }
              },
              "additionalProperties": false
            }
          },
          "nota": { "type": "string", "minLength": 10 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
