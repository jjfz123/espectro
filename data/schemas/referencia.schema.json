{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "referencia.schema.json",
  "title": "Perfil doctrinal de referencia",
  "type": "object",
  "required": [
    "id",
    "nombre",
    "tipo",
    "definicion",
    "confianza",
    "version",
    "revisado",
    "facetasDefinitorias",
    "advertencia",
    "fuentesMarco",
    "reglaPublicacion",
    "posiciones"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "nombre": { "type": "string", "minLength": 3 },
    "tipo": { "const": "referencia-doctrinal" },
    "definicion": { "type": "string", "minLength": 40, "maxLength": 800 },
    "variante": { "type": "string" },
    "periodo": { "type": "string" },
    "confianza": { "enum": ["verificada", "estimada", "sin-datos"] },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "revisado": { "type": "string", "format": "date" },
    "publicacionMapa": {
      "type": "object",
      "required": ["publicable", "motivo"],
      "properties": {
        "publicable": { "type": "boolean" },
        "motivo": { "type": "string", "minLength": 40, "maxLength": 500 }
      },
      "additionalProperties": false,
      "description": "Control editorial independiente del matching doctrinal: permite retirar una proyección macro insuficientemente equilibrada sin borrar la referencia."
    },
    "publicacionAfinidad": {
      "type": "object",
      "required": ["publicable", "motivo"],
      "properties": {
        "publicable": { "type": "boolean" },
        "motivo": { "type": "string", "minLength": 40, "maxLength": 500 }
      },
      "additionalProperties": false,
      "description": "Puerta separada para la comparación doctrinal. Una ficha en auditoría puede seguir documentada sin producir afinidad visible."
    },
    "facetasDefinitorias": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
    },
    "sensibilidad": { "enum": ["normal", "antipluralista", "violenta"] },
    "advertencia": { "type": "string", "minLength": 40, "maxLength": 800 },
    "fuentesMarco": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/fuente" }
    },
    "reglaPublicacion": {
      "type": "object",
      "required": ["minimoItems", "minimoCobertura", "umbralAfinidad"],
      "properties": {
        "minimoItems": { "type": "integer", "minimum": 3 },
        "minimoCobertura": { "type": "number", "minimum": 0, "maximum": 1 },
        "umbralAfinidad": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "posiciones": {
      "type": "object",
      "minProperties": 3,
      "patternProperties": {
        "^[a-z0-9-]+$": {
          "type": "object",
          "required": ["valor", "justificacion", "calidadEvidencia", "fuente"],
          "properties": {
            "valor": { "type": "integer", "minimum": -2, "maximum": 2 },
            "justificacion": { "type": "string", "minLength": 20, "maxLength": 500 },
            "calidadEvidencia": { "enum": ["alta", "media", "baja"] },
            "resolucionCero": {
              "type": "object",
              "required": ["tipo", "explicacion"],
              "properties": {
                "tipo": { "enum": ["modelo-mixto", "equilibrio-explicito"] },
                "explicacion": { "type": "string", "minLength": 30, "maxLength": 500 }
              },
              "additionalProperties": false
            },
            "grupoEvidencia": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]{5,100}$"
            },
            "fuente": { "$ref": "#/definitions/fuente" }
          },
          "allOf": [
            {
              "if": {
                "required": ["fuente"],
                "properties": { "fuente": { "type": "object", "required": ["cita"] } }
              },
              "then": { "required": ["grupoEvidencia"] }
            }
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "definitions": {
    "fuente": {
      "type": "object",
      "required": ["tipo", "titulo", "url", "consultado"],
      "properties": {
        "tipo": { "enum": ["programa", "votacion", "declaracion", "autoubicacion", "estatutos", "redes", "otro"] },
        "titulo": { "type": "string", "minLength": 3 },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "fecha": { "type": "string", "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$" },
        "consultado": { "type": "string", "format": "date" },
        "cita": { "type": "string", "maxLength": 500 }
      },
      "additionalProperties": false
    }
  }
}
