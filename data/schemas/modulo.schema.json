{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "modulo.schema.json",
  "title": "Módulo de ítems",
  "type": "object",
  "required": ["id", "nombre", "desbloqueo"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "nombre": { "type": "string" },
    "descripcion": { "type": "string" },
    "orden": { "type": "integer" },
    "eleccionUsuario": { "type": "boolean", "description": "El usuario puede activarlo manualmente aunque no se desbloquee" },
    "desbloqueo": {
      "type": "object",
      "required": ["tipo"],
      "properties": {
        "tipo": { "enum": ["siempre", "eje", "eje-banda", "ccaa"] },
        "eje": { "type": "string" },
        "operador": { "enum": ["<=", ">="] },
        "umbral": { "type": "number", "minimum": -100, "maximum": 100 },
        "min": { "type": "number", "minimum": -100, "maximum": 100, "description": "eje-banda: límite inferior de la franja" },
        "max": { "type": "number", "minimum": -100, "maximum": 100, "description": "eje-banda: límite superior de la franja" },
        "ccaa": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" }, "minItems": 1 }
          ],
          "description": "Una CCAA o varias (módulos territoriales compartidos)"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
