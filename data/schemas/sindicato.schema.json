{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sindicato.schema.json",
  "title": "Organización sindical",
  "type": "object",
  "required": ["id", "nombre", "ambito", "confianza", "revisado", "posiciones"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "nombre": { "type": "string" },
    "siglas": { "type": "string" },
    "ambito": { "enum": ["estatal", "autonomico", "territorial", "sectorial"] },
    "ccaa": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "sectores": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "confianza": { "enum": ["verificada", "estimada", "sin-datos"] },
    "demo": { "type": "boolean" },
    "web": { "type": "string", "format": "uri", "pattern": "^https://" },
    "revisado": { "type": "string", "format": "date" },
    "advertencia": { "type": "string", "maxLength": 500 },
    "posiciones": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9-]+$": {
          "type": "object",
          "required": ["valor"],
          "properties": {
            "valor": { "type": "integer", "minimum": -2, "maximum": 2 },
            "justificacion": { "type": "string", "maxLength": 500 },
            "calidadEvidencia": { "enum": ["alta", "media", "baja"] },
            "fuente": {
              "type": "object",
              "required": ["tipo"],
              "properties": {
                "tipo": { "enum": ["programa", "votacion", "declaracion", "autoubicacion", "estatutos", "redes", "otro"] },
                "titulo": { "type": "string" },
                "url": { "type": "string", "format": "uri", "pattern": "^https://" },
                "fecha": { "type": "string", "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$", "description": "Fecha con la precisión publicada por la fuente: AAAA, AAAA-MM o AAAA-MM-DD" },
                "consultado": { "type": "string", "format": "date" },
                "cita": { "type": "string", "maxLength": 500 }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
