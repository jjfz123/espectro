{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sindicato.schema.json",
  "title": "Organización sindical",
  "type": "object",
  "required": [
    "id",
    "nombre",
    "ambito",
    "confianza",
    "revisado",
    "posiciones"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "nombre": {
      "type": "string"
    },
    "siglas": {
      "type": "string"
    },
    "ambito": {
      "enum": [
        "estatal",
        "autonomico",
        "territorial",
        "sectorial"
      ]
    },
    "ccaa": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "sectores": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "confianza": {
      "enum": [
        "verificada",
        "estimada",
        "sin-datos"
      ]
    },
    "demo": {
      "type": "boolean"
    },
    "web": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "revisado": {
      "type": "string",
      "format": "date"
    },
    "advertencia": {
      "type": "string",
      "maxLength": 500
    },
    "posiciones": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9-]+$": {
          "type": "object",
          "required": [
            "valor"
          ],
          "properties": {
            "valor": {
              "type": "integer",
              "minimum": -2,
              "maximum": 2
            },
            "justificacion": {
              "type": "string",
              "maxLength": 500
            },
            "calidadEvidencia": {
              "enum": [
                "alta",
                "media",
                "baja"
              ]
            },
            "resolucionCero": {
              "type": "object",
              "required": ["tipo", "explicacion"],
              "properties": {
                "tipo": { "enum": ["modelo-mixto", "equilibrio-explicito"] },
                "explicacion": { "type": "string", "minLength": 30, "maxLength": 500 }
              },
              "additionalProperties": false
            },
            "grupoEvidencia": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]{5,100}$"
            },
            "fuente": {
              "type": "object",
              "required": [
                "tipo"
              ],
              "properties": {
                "tipo": {
                  "enum": [
                    "programa",
                    "votacion",
                    "declaracion",
                    "autoubicacion",
                    "estatutos",
                    "redes",
                    "otro"
                  ]
                },
                "titulo": {
                  "type": "string"
                },
                "url": {
                  "type": "string",
                  "format": "uri",
                  "pattern": "^https://"
                },
                "fecha": {
                  "type": "string",
                  "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$",
                  "description": "Fecha con la precisión publicada por la fuente: AAAA, AAAA-MM o AAAA-MM-DD"
                },
                "consultado": {
                  "type": "string",
                  "format": "date"
                },
                "cita": {
                  "type": "string",
                  "maxLength": 500
                }
              },
              "additionalProperties": false
            }
          },
          "allOf": [
            {
              "if": {
                "required": ["fuente"],
                "properties": { "fuente": { "type": "object", "required": ["cita"] } }
              },
              "then": { "required": ["grupoEvidencia"] }
            }
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "autodescripcion": {
      "type": "object",
      "required": [
        "texto",
        "fuente"
      ],
      "properties": {
        "texto": {
          "type": "string",
          "description": "Cómo se define el propio partido, con sus palabras (estatutos, web, manifiesto)"
        },
        "fuente": {
          "type": "object",
          "required": [
            "titulo",
            "url"
          ],
          "properties": {
            "tipo": {
              "type": "string"
            },
            "titulo": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "fecha": {
              "type": "string"
            },
            "cita": {
              "type": "string",
              "maxLength": 500
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "clasificacion": {
      "type": "array",
      "description": "Etiquetas analíticas externas SIEMPRE atribuidas: politología, prensa de referencia. Cada una con explicación llana del término y fuente.",
      "items": {
        "type": "object",
        "required": [
          "etiqueta",
          "explicacion",
          "fuente"
        ],
        "properties": {
          "etiqueta": {
            "type": "string"
          },
          "explicacion": {
            "type": "string",
            "minLength": 40,
            "description": "Qué significa el término, en llano y sin caricatura"
          },
          "fuente": {
            "type": "object",
            "required": [
              "titulo",
              "url"
            ],
            "properties": {
              "tipo": {
                "type": "string"
              },
              "titulo": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "fecha": {
                "type": "string"
              },
              "cita": {
                "type": "string",
                "maxLength": 500
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
