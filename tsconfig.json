{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@engine": ["src/engine/index.ts"],
      "@engine/*": ["src/engine/*"],
      "@data/*": ["data/*"]
    }
  },
  "include": ["src", "tests", "types"]
}
